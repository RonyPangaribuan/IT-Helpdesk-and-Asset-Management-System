APP_NAME=deskIT
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_SECURE_COOKIE=true

CACHE_STORE=database
QUEUE_CONNECTION=sync

FILESYSTEM_DISK=local
TICKET_ATTACHMENT_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Deployment notes:
# - Generate APP_KEY during deployment with: php artisan key:generate
# - Store database credentials in the hosting secret manager.
# - APP_DEBUG=false is required in production.
# - The local attachment disk requires persistent private storage.
# - A private S3-compatible disk may be used when configured and tested.
# - Never commit a real .env file.
